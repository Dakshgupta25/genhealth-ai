# ─── Application ─────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-256-bit-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRE_MINUTES=10

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://genhealth:password@localhost:5432/genhealth
# For sync operations (Alembic migrations):
SYNC_DATABASE_URL=postgresql://genhealth:password@localhost:5432/genhealth

# ─── MongoDB ─────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=genhealth

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AWS S3 / MinIO ──────────────────────────────────────────────────
# For production (AWS S3):
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=genhealth-records

# For local development (MinIO):
S3_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=genhealth-records

# ─── Email (SendGrid) ────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
FROM_EMAIL=noreply@genhealth.ai
FROM_NAME=GenHealth AI

# ─── Frontend ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ─── Celery ──────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── File Upload ─────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=["jpg","jpeg","png","pdf","heic"]

# ─── ML / OCR ────────────────────────────────────────────────────────
# Google Vision API (for production OCR):
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# Or use Tesseract (local):
TESSERACT_CMD=/usr/bin/tesseract

# ─── Invite ──────────────────────────────────────────────────────────
INVITE_TOKEN_EXPIRE_HOURS=72
INVITE_BASE_URL=http://localhost:3000/invite
